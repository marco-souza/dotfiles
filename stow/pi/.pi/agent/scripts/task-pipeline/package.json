{
  "name": "task-pipeline",
  "version": "1.0.0",
  "private": true,
  "description": "DAG task execution tools for the pi agent — validate, status, prompts, and tmux-based wave spawning",
  "type": "module",
  "module": "src/cli.ts",
  "main": "src/cli.ts",
  "bin": {
    "task-pipeline": "src/cli.ts"
  },
  "scripts": {
    "validate": "bun src/cli.ts validate",
    "status": "bun src/cli.ts status",
    "prompts": "bun src/cli.ts prompts",
    "spawn": "bun src/cli.ts spawn",
    "start": "bun src/cli.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "pi-agent",
    "tasks",
    "dag",
    "pipeline",
    "tmux",
    "cli"
  ]
}
